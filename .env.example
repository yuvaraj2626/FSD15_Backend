# ═══════════════════════════════════════════════════════════════
# MERN Complaint Management System - Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── SERVER ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── FRONTEND ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api

# ── DATABASE ──────────────────────────────────────────────────
# MongoDB connection URI
# For local development:
#   MONGODB_URI=mongodb://localhost:27017/complaints_db
# For MongoDB Atlas:
#   MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/complaints_db

# ── JWT TOKENS ────────────────────────────────────────────────
# Use strong, random strings in production
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── EMAIL SERVICE (Nodemailer) ────────────────────────────────
# SMTP Configuration for sending complaint notifications and escalation alerts
# 
# Example: Gmail
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USER=your-email@gmail.com
#   EMAIL_PASS=your-app-specific-password  (NOT your regular password)
#
# Example: SendGrid
#   EMAIL_HOST=smtp.sendgrid.net
#   EMAIL_PORT=587
#   EMAIL_USER=apikey
#   EMAIL_PASS=SG.xxxxxxxxxxxx...
#
# Example: Mailgun
#   EMAIL_HOST=smtp.mailgun.org
#   EMAIL_PORT=587
#   EMAIL_USER=postmaster@domain.com
#   EMAIL_PASS=your-mailgun-password
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=noreply@complaints-system.local

# If EMAIL_USER or EMAIL_PASS not set, emails will be logged but NOT sent (development mode)

# ── SLA & ESCALATION SCHEDULER ────────────────────────────────
# How often the SLA scheduler checks for complaints that have exceeded their SLA deadline
# and need to be escalated. Value in milliseconds.
#
# Common values:
#   1 min  = 60000
#   5 min  = 300000  (recommended for development)
#   15 min = 900000
#   1 hour = 3600000
#
SLA_CHECK_INTERVAL_MS=300000

# ── RATE LIMITING ─────────────────────────────────────────────
# Rate limiting configuration for API endpoints
# Requests per minute
RATE_LIMIT_WINDOW_MS=60000      # 1 minute window
RATE_LIMIT_MAX_REQUESTS=100      # Max 100 requests per minute on general /api routes
RATE_LIMIT_AUTH_MAX_REQUESTS=5   # Max 5 requests per minute on auth routes

# ── FILE UPLOADS ──────────────────────────────────────────────
# Max upload file size in bytes
MAX_FILE_SIZE=5242880            # 5 MB
UPLOAD_DIR=./uploads

# ── CORS & SECURITY ───────────────────────────────────────────
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# Session/Cookie settings
SESSION_SECRET=your_session_secret_change_this_in_production

# ── LOGGING ───────────────────────────────────────────────────
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# ── TIMEZONE ──────────────────────────────────────────────────
# Timezone for scheduler cron expressions
# Examples: UTC, America/New_York, Europe/London, Asia/Kolkata
TZ=UTC

# ── TESTING (Optional) ────────────────────────────────────────
# Test user credentials (used only in testing)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testPassword123
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminPassword123

# ═══════════════════════════════════════════════════════════════
# PRODUCTION GUIDELINES
# ═══════════════════════════════════════════════════════════════
#
# 1. NEVER commit actual credentials to .env file
# 2. Use strong random values for all secrets (at least 32 characters)
# 3. Use environment-specific values (staging, production)
# 4. Rotate JWT secrets periodically
# 5. Use MongoDB Atlas with authentication in production
# 6. Enable SSL/TLS for email and database connections
# 7. Set NODE_ENV=production in production
# 8. Configure proper CORS origins (not * or localhost)
# 9. Use environment variable management service (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# ═══════════════════════════════════════════════════════════════
